%%{init: {"flowchart": {"defaultRenderer": "elk"}}}%%
flowchart LR
    START([New Frame]) --> BGR2HSV[BGR → HSV]
    BGR2HSV --> HASCAL{roi_hist\ncalibrated?}
    HASCAL -- No --> CALIB([Calibration UI\nreturn frame])
    HASCAL -- Yes --> HASWIN{track_win set\nAND detect_count ≥ 3?}

    HASWIN -- No --> DETECT_WARM{track_win\nset?}

    DETECT_WARM -- Yes --> WSEARCH[Mask search\nin padded ROI]
    DETECT_WARM -- No --> CSEARCH[Mask full frame\nall 3 methods + vote]
    WSEARCH --> BLOBFIND[_nearest_blob_rect]
    CSEARCH --> BLOBFIND
    BLOBFIND --> BLOBFOUND{blob\nfound?}
    BLOBFOUND -- Yes --> INCCOUNT[detect_count++\nupdate track_win]
    BLOBFOUND -- No --> RESETCOUNT[detect_count = 0\ntrack_win = None]
    INCCOUNT --> COUNT3{detect_count == 3\nAND tracker set?}
    COUNT3 -- Yes --> INITTRK[Init TrackerMIL\nwith padded bbox]
    COUNT3 -- No --> NOTLOCKED([return frame\nnot locked])
    INITTRK --> NOTLOCKED
    RESETCOUNT --> NOTLOCKED

    HASWIN -- Yes --> TRACKERSEL{tracker_name\nset?}

    %% ── MIL path ──────────────────────────────────────────────────────────────
    TRACKERSEL -- Yes --> MILUPD[TrackerMIL.update]
    MILUPD --> MILOK{ok AND\nw,h ≥ 4?}
    MILOK -- No --> MILRESET([Hard reset\nreturn frame])
    MILOK -- Yes --> COLORVAL[_detection_mask on ROI\ncountNonZero]
    COLORVAL --> COLORPASS{pixels ≥\n_MIN_BLOB_AREA?}
    COLORPASS -- No --> MISSINC[miss_count++]
    MISSINC --> MISSMAX{miss_count ≥\n_KF_MISS_MAX?}
    MISSMAX -- Yes --> MILRESET
    MISSMAX -- No --> MILCOAST([return frame\ncoasting])
    COLORPASS -- Yes --> MILGOOD[miss_count = 0\nupdate track_win + EMA]
    MILGOOD --> KFBLOCK

    %% ── CamShift path ─────────────────────────────────────────────────────────
    TRACKERSEL -- No --> PRETRANS[Pre-translate window\nby Kalman velocity]
    PRETRANS --> BACKPROJ[calcBackProject\nwith Gaussian hist]
    BACKPROJ --> GATE[Gate to padded\nsearch ROI]
    GATE --> BLUR[GaussianBlur + dilate]
    BLUR --> SHIFTALGO{shift_algo?}
    SHIFTALGO -- camshift --> CAMSH[cv2.CamShift]
    SHIFTALGO -- meanshift --> MEANSH[cv2.meanShift]
    CAMSH --> CLAMP[Clamp window\nto frame bounds]
    MEANSH --> CLAMP
    CLAMP --> WINVALID{window bad OR\ndensity < 5%?}

    WINVALID -- No --> BLOBSNAP{blob disagrees\nwith shift centre?}
    BLOBSNAP -- Yes --> SNAPWIN[Snap track_win\nto blob bbox]
    BLOBSNAP -- No --> RAWCXCY[raw_cx/cy\nfrom shift centre]
    SNAPWIN --> RAWCXCY

    WINVALID -- Yes --> KFINIT{Kalman init AND\nmiss_count < _KF_MISS_MAX?}
    KFINIT -- No --> CSRESET([Hard reset\nreturn frame])
    KFINIT -- Yes --> KFPRED([Kalman predict-only\nmiss_count++\nreturn predicted cx,cy])

    RAWCXCY --> KFBLOCK

    %% ── Kalman filter ─────────────────────────────────────────────────────────
    subgraph KFBLOCK["📐 Kalman Filter"]
        direction TB
        KFQ{use_kalman?}
        KFQ -- No --> CXY_RAW[cx,cy = raw]
        KFQ -- Yes --> KFREADY{kf_initialized?}
        KFREADY -- No --> KFINIT2[Init: pos=raw\nvel=0]
        KFREADY -- Yes --> KFUPD[predict + correct\nwith raw_cx, raw_cy]
        KFINIT2 --> CXY_KF[cx,cy = KF estimate]
        KFUPD --> CXY_KF
    end

    CXY_RAW --> ERRORXY
    CXY_KF --> ERRORXY

    %% ── Error + PN lead ───────────────────────────────────────────────────────
    subgraph PRED["⏩ Error + PN Lead"]
        direction TB
        ERRORXY[errorx = cx−W/2 / W/2\nerrory = −cy−H/2 / H/2]
        ERRORXY --> PREDCHECK{input_prediction\nenabled?}
        PREDCHECK -- Yes --> PNLEAD[ex += ėx·τ_L + T_PN\ney += ėy·τ_L + T_PN]
        PREDCHECK -- No --> SENDOUT
        PNLEAD --> SENDOUT
    end

    SENDOUT([return cx, cy\n→ DEBUG_VECT to FC])

    style CALIB fill:#888,color:#fff
    style NOTLOCKED fill:#888,color:#fff
    style MILRESET fill:#c0392b,color:#fff
    style CSRESET fill:#c0392b,color:#fff
    style MILCOAST fill:#e67e22,color:#fff
    style KFPRED fill:#e67e22,color:#fff
    style SENDOUT fill:#27ae60,color:#fff
