---
title: Logika Kontrol Tracking — loop per-frame
---
flowchart TD
    START(["`**Mulai loop frame**`"])

    START --> READ["`Jalankan tracker aktif
    CamShift / MeanShift / MIL / CSRT /
    DaSiamRPN / Nano / ViT + filter Kalman
    → cx, cy`"]

    READ --> KFPRED{"`seeker track?
    _(cx adalah None)_`"}

    KFPRED -- "`miss_count < 5
    Kalman prediksi saja`" --> KF_HOLD["`Kembalikan cx, cy terprediksi
    target_locked = **True**
    miss_count++`"]
    KFPRED -- "`miss_count ≥ 5`" --> KF_RESET["`Reset tracker penuh
    target_locked = **False**`"]
    KFPRED -- "`Lacak OK`" --> KF_OK["`Perbarui filter Kalman
    target_locked = **True**
    miss_count = 0`"]

    KF_HOLD --> POLL
    KF_RESET --> POLL
    KF_OK --> POLL

    POLL["`Poll RC / telemetri MAVLink`"]
    POLL --> AUTOMODE{auto_mode?}

    %% ── Rule 3: auto_mode = False ────────────────────────────────────────────
    AUTOMODE -- Tidak --> CH6_R3{ch6?}

    CH6_R3 -- "`TINGGI → RENDAH
    _(tepi turun)_`" --> FELL_R3["`_in_tracking = False
    Set **AUTO**`"]

    CH6_R3 -- "RENDAH / stabil" --> SKIP_R3[ ]

    CH6_R3 -- "`TINGGI + target_terkunci
    + BUKAN _in_tracking`" --> ENTER_R3["`Set **TRACKING**
    _in_tracking = True`"]

    FELL_R3    --> FEED
    SKIP_R3    --> FEED
    ENTER_R3   --> FEED

    %% ── Rule 1 & 2: auto_mode = True ────────────────────────────────────────
    AUTOMODE -- Ya --> WPCHECK{"`cukup_dekat < 1000 m
    DAN wp_terakhir
    DAN target_terkunci
    DAN BUKAN _in_tracking?`"}

    WPCHECK -- Ya --> ENTER_AUTO["`Set **TRACKING**
    _in_tracking = True`"]

    WPCHECK -- Tidak --> JOYCHECK{joystick ON?}

    JOYCHECK -- "`Ya (Rule 1)
    ch6 RENDAH`" --> SET_STAB["`Set **STABILIZE**`"]

    JOYCHECK -- "`Ya (Rule 1)
    ch6 TINGGI`" --> SET_AUTO["`Set **AUTO**`"]

    JOYCHECK -- "`Tidak (Rule 2)
    (ch6 diabaikan)`" --> SET_AUTO

    ENTER_AUTO --> FEED
    SET_STAB   --> FEED
    SET_AUTO   --> FEED

    %% ── Feed tracking error ──────────────────────────────────────────────────
    FEED{"`_in_tracking
    DAN mode == TRACKING?`"}

    FEED -- Tidak --> ANNOTATE
    FEED -- Ya --> TGT{target_terkunci?}

    TGT -- Ya --> PN["`Terapkan prediksi PN lead
    simpan last_errorx, last_errory
    lost_count = 0`"]

    PN --> SEND_ERR["`Kirim error tracking
    _(errorx, errory)_
    Log baris CSV`"]

    SEND_ERR --> TERM{"`in_terminal?
    alt_rel_m ≤ TRK_TERM_ALT`"}
    TERM -- Ya --> LOG_T["`Log terminal = 1`"]
    TERM -- Tidak  --> LOG_N["`Log terminal = 0`"]

    TGT -- Tidak --> LOSTCNT["`lost_count++
    committed = entry_count ≥ 3
    batas = 30 jika committed, 10 jika tidak`"]

    LOSTCNT --> LOSTLIM{"`lost_count ≥ batas?`"}
    LOSTLIM -- Ya --> FORCE_AUTO["`lost_count = 0
    _in_tracking = False
    Set **AUTO**`"]

    LOSTLIM -- Tidak --> COMMITTED{committed?}
    COMMITTED -- Ya --> SEND_LAST["`Kirim last_errorx, last_errory
    _(tahan arah terakhir diketahui)_`"]
    COMMITTED -- Tidak  --> SEND_ZERO["`Kirim 0.0, 0.0
    _(sayap rata)_`"]

    LOG_T        --> ANNOTATE
    LOG_N        --> ANNOTATE
    FORCE_AUTO   --> ANNOTATE
    SEND_LAST    --> ANNOTATE
    SEND_ZERO    --> ANNOTATE

    ANNOTATE(["`Gambar HUD + tampilkan frame`"])
    ANNOTATE --> START

    %% ── style ────────────────────────────────────────────────────────────────
    classDef modeCmd    fill:#1a6fb5,color:#fff,stroke:#0d4a80,font-weight:bold
    classDef decision   fill:#f0c040,color:#222,stroke:#b89000
    classDef action     fill:#2d8a4e,color:#fff,stroke:#1a5c33
    classDef term_node  fill:#c0392b,color:#fff,stroke:#922b21,font-weight:bold
    classDef endpoint   fill:#555,color:#fff,stroke:#333

    class FELL_R3,SET_STAB,SET_AUTO,ENTER_AUTO,ENTER_R3,FORCE_AUTO modeCmd
    class AUTOMODE,CH6_R3,WPCHECK,JOYCHECK,FEED,TGT,LOSTLIM,COMMITTED,TERM,KFPRED decision
    class PN,SEND_ERR,SEND_LAST,SEND_ZERO,LOG_T,LOG_N,LOSTCNT action
    class LOG_T,TERM term_node
    class START,ANNOTATE endpoint
